// 1. Delete the first node (deleteHead)

deleteHead() {
    if (!this.head) return null;
    this.head = this.head.next;
    this.size--;
}


// 2. Delete the last node (deleteTail)

deleteTail() {
    if (!this.head) return null;

    // If only one node
    if (!this.head.next) {
        this.head = null;
        this.size--;
        return;
    }

    let curr = this.head;
    let prev = null;

    while (curr.next) {
        prev = curr;
        curr = curr.next;
    }

    prev.next = null;
    this.size--;
}


// 3. Get value at index (getAtIndex)

getAtIndex(index) {
    if (index < 0 || index >= this.size) return null;

    let curr = this.head;
    let i = 0;

    while (i < index) {
        curr = curr.next;
        i++;
    }
    return curr.value;
}


// 4. Insert at index (insertAtIndex)

insertAtIndex(index, value) {
    if (index < 0 || index > this.size) return;

    const node = new Node(value);

    if (index === 0) {
        this.prepend(value);
        return;
    }

    let curr = this.head;
    let i = 0;

    while (i < index - 1) {
        curr = curr.next;
        i++;
    }

    node.next = curr.next;
    curr.next = node;
    this.size++;
}

// Convert LinkedList → Array

toArray() {
    let arr = [];
    let curr = this.head;

    while (curr) {
        arr.push(curr.value);
        curr = curr.next;
    }

    return arr;
}

// 6. Count occurrences of a value

countOccurrences(value) {
    let count = 0;
    let curr = this.head;

    while (curr) {
        if (curr.value === value) count++;
        curr = curr.next;
    }

    return count;
}

// 7. Remove duplicates (unsorted list)

removeDuplicates() {
    let seen = new Set();
    let curr = this.head;
    let prev = null;

    while (curr) {
        if (seen.has(curr.value)) {
            prev.next = curr.next;
            this.size--;
        } else {
            seen.add(curr.value);
            prev = curr;
        }
        curr = curr.next;
    }
}

// 8. Check if the list is sorted

isSorted() {
    if (!this.head) return true;

    let curr = this.head;

    while (curr.next) {
        if (curr.value > curr.next.value) return false;
        curr = curr.next;
    }

    return true;
}

// 9. Find nth node from end (two pointer method)

nthFromEnd(n) {
    let fast = this.head;
    let slow = this.head;

    // Move fast n steps
    for (let i = 0; i < n; i++) {
        if (!fast) return null;
        fast = fast.next;
    }

    // Move both until fast reaches end
    while (fast) {
        fast = fast.next;
        slow = slow.next;
    }

    return slow.value;
}



// 10. Swap two nodes by value

swapNodes(val1, val2) {
    if (val1 === val2) return;

    let prev1 = null, curr1 = this.head;
    let prev2 = null, curr2 = this.head;

    // Find val1
    while (curr1 && curr1.value !== val1) {
        prev1 = curr1;
        curr1 = curr1.next;
    }

    // Find val2
    while (curr2 && curr2.value !== val2) {
        prev2 = curr2;
        curr2 = curr2.next;
    }

    if (!curr1 || !curr2) return;

    // If val1 is not head
    if (prev1) prev1.next = curr2;
    else this.head = curr2;

    // If val2 is not head
    if (prev2) prev2.next = curr1;
    else this.head = curr1;

    // Swap next pointers
    let temp = curr1.next;
    curr1.next = curr2.next;
    curr2.next = temp;
}


