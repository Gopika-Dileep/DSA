//  1. Detect a Cycle in Linked List (Floyd’s Algorithm)

hasCycle() {
    let slow = this.head;
    let fast = this.head;

    while (fast && fast.next) {
        slow = slow.next;
        fast = fast.next.next;

        if (slow === fast) return true;
    }
    return false;
}



// 2. Remove Cycle in Linked List

removeCycle() {
    let slow = this.head;
    let fast = this.head;

    // Step 1: Detect loop
    while (fast && fast.next) {
        slow = slow.next;
        fast = fast.next.next;

        if (slow === fast) break;
    }

    // No cycle
    if (!fast || !fast.next) return;

    // Step 2: Move slow to head
    slow = this.head;

    // Step 3: Find the start of loop
    while (slow !== fast) {
        slow = slow.next;
        fast = fast.next;
    }

    // Step 4: Find the last node of the loop
    let ptr = slow;
    while (ptr.next !== slow) {
        ptr = ptr.next;
    }

    ptr.next = null;  // break the loop
}



// 3. Check if Linked List is Palindrome

isPalindrome() {
    let arr = [];
    let curr = this.head;

    while (curr) {
        arr.push(curr.value);
        curr = curr.next;
    }

    let i = 0, j = arr.length - 1;

    while (i < j) {
        if (arr[i] !== arr[j]) return false;
        i++;
        j--;
    }
    return true;
}



// 4. Merge Two Sorted Linked Lists

merge(l1, l2) {
    let dummy = new Node(0);
    let curr = dummy;

    while (l1 && l2) {
        if (l1.value < l2.value) {
            curr.next = l1;
            l1 = l1.next;
        } else {
            curr.next = l2;
            l2 = l2.next;
        }
        curr = curr.next;
    }

    curr.next = l1 || l2;
    return dummy.next;
}



// 5. Delete Nth Node From End (One Pass / Two Pointers)

deleteNthFromEnd(n) {
    let dummy = new Node(0);
    dummy.next = this.head;

    let slow = dummy;
    let fast = dummy;

    // Move fast n+1 steps
    for (let i = 0; i <= n; i++) {
        if (!fast) return;
        fast = fast.next;
    }

    // Move both until fast reaches end
    while (fast) {
        slow = slow.next;
        fast = fast.next;
    }

    slow.next = slow.next.next;
    this.head = dummy.next;
    this.size--;
}



// 6. Rotate Linked List (Right Rotation)

rotate(k) {
    if (!this.head || k === 0) return;

    // compute length
    let len = 1;
    let tail = this.head;
    while (tail.next) {
        tail = tail.next;
        len++;
    }

    k = k % len;
    if (k === 0) return;

    // make it circular
    tail.next = this.head;

    // find new tail: len - k
    let steps = len - k;
    let newTail = this.head;

    while (steps > 1) {
        newTail = newTail.next;
        steps--;
    }

    this.head = newTail.next;
    newTail.next = null;
}



// 7. Remove All Nodes With a Given Value

removeAll(value) {
    // Remove from head
    while (this.head && this.head.value === value) {
        this.head = this.head.next;
        this.size--;
    }

    let curr = this.head;
    while (curr && curr.next) {
        if (curr.next.value === value) {
            curr.next = curr.next.next;
            this.size--;
        } else {
            curr = curr.next;
        }
    }
}





// 8. Add Two Numbers Represented as Linked Lists

addTwoNumbers(l1, l2) {
    let dummy = new Node(0);
    let curr = dummy;
    let carry = 0;

    while (l1 || l2 || carry) {
        let sum = carry;

        if (l1) {
            sum += l1.value;
            l1 = l1.next;
        }

        if (l2) {
            sum += l2.value;
            l2 = l2.next;
        }

        carry = Math.floor(sum / 10);
        curr.next = new Node(sum % 10);
        curr = curr.next;
    }

    return dummy.next;
}




// 9. Sort Linked List (Merge Sort Algorithm)

sortList(head = this.head) {
    if (!head || !head.next) return head;

    // find middle
    let slow = head;
    let fast = head;

    while (fast.next && fast.next.next) {
        slow = slow.next;
        fast = fast.next.next;
    }

    let mid = slow.next;
    slow.next = null;

    let left = this.sortList(head);
    let right = this.sortList(mid);

    return this.merge(left, right);
}




// 10. Partition Linked List Around Value X

partition(x) {
    let smallerHead = new Node(0);
    let greaterHead = new Node(0);

    let small = smallerHead;
    let big = greaterHead;

    let curr = this.head;

    while (curr) {
        if (curr.value < x) {
            small.next = curr;
            small = small.next;
        } else {
            big.next = curr;
            big = big.next;
        }
        curr = curr.next;
    }

    // connect both lists
    big.next = null;
    small.next = greaterHead.next;

    this.head = smallerHead.next;
}





