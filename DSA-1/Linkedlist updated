// 1. Flatten a Multilevel Linked List

flatten(head = this.head) {
    if (!head) return null;

    let stack = [];
    let curr = head;

    while (curr) {
        if (curr.child) {
            if (curr.next) stack.push(curr.next);

            curr.next = curr.child;
            curr.child = null;
        }

        if (!curr.next && stack.length > 0) {
            curr.next = stack.pop();
        }

        curr = curr.next;
    }

    return head;
}




// 2. Reorder List

reorder() {
    if (!this.head || !this.head.next) return;

    // Step 1: find middle
    let slow = this.head, fast = this.head;
    while (fast && fast.next) {
        slow = slow.next;
        fast = fast.next.next;
    }

    // Step 2: reverse from slow
    let prev = null, curr = slow;
    while (curr) {
        let next = curr.next;
        curr.next = prev;
        prev = curr;
        curr = next;
    }

    // Step 3: merge first + reversed
    let first = this.head;
    let second = prev;

    while (second.next) {
        let temp1 = first.next;
        let temp2 = second.next;

        first.next = second;
        second.next = temp1;

        first = temp1;
        second = temp2;
    }
}




// 3. Clone a List With Random Pointers

cloneRandomList(head) {
    if (!head) return null;

    let curr = head;

    // Step 1: Insert cloned nodes
    while (curr) {
        let copy = new Node(curr.value);
        copy.next = curr.next;
        curr.next = copy;
        curr = copy.next;
    }

    // Step 2: Assign random pointers
    curr = head;
    while (curr) {
        if (curr.random) {
            curr.next.random = curr.random.next;
        }
        curr = curr.next.next;
    }

    // Step 3: Separate original and cloned list
    curr = head;
    let cloneHead = head.next;

    while (curr) {
        let copy = curr.next;
        curr.next = copy.next;

        if (copy.next) copy.next = copy.next.next;
        curr = curr.next;
    }

    return cloneHead;
}



// 4. Reverse Nodes in k-Groups

reverseKGroup(head, k) {
    if (!head || k === 1) return head;

    let dummy = new Node(0);
    dummy.next = head;

    let prev = dummy, end = dummy;

    while (true) {
        for (let i = 0; i < k && end; i++) end = end.next;
        if (!end) break;

        let start = prev.next;
        let next = end.next;

        end.next = null;

        prev.next = this.reverseList(start);
        start.next = next;

        prev = start;
        end = prev;
    }

    return dummy.next;
}

// helper
reverseList(head) {
    let prev = null, curr = head;

    while (curr) {
        let next = curr.next;
        curr.next = prev;
        prev = curr;
        curr = next;
    }

    return prev;
}



// 5. Find Intersection of Two Linked Lists

getIntersection(headA, headB) {
    if (!headA || !headB) return null;

    let a = headA;
    let b = headB;

    while (a !== b) {
        a = a ? a.next : headB;
        b = b ? b.next : headA;
    }

    return a;  // or null

}




// 6. Remove Duplicates from a Sorted Linked List (LeetCode #83)

removeSortedDuplicates() {
    let curr = this.head;

    while (curr && curr.next) {
        if (curr.value === curr.next.value) {
            curr.next = curr.next.next;
            this.size--;
        } else {
            curr = curr.next;
        }
    }
}




// 7. Remove Duplicates from Unsorted List Without Extra Space

removeDupNoBuffer() {
    let curr = this.head;

    while (curr) {
        let runner = curr;

        while (runner.next) {
            if (runner.next.value === curr.value) {
                runner.next = runner.next.next;
                this.size--;
            } else {
                runner = runner.next;
            }
        }

        curr = curr.next;
    }
}




// 8. Pairwise Swap Nodes

pairwiseSwap() {
    let dummy = new Node(0);
    dummy.next = this.head;

    let curr = dummy;

    while (curr.next && curr.next.next) {
        let first = curr.next;
        let second = curr.next.next;

        first.next = second.next;
        second.next = first;
        curr.next = second;

        curr = curr.next.next;
    }

    this.head = dummy.next;
}




// 9. Delete Middle Node (O(1) space)

deleteMiddleNode() {
    if (!this.head || !this.head.next) {
        this.head = null;
        return;
    }

    let slow = this.head;
    let fast = this.head;
    let prev = null;

    while (fast && fast.next) {
        prev = slow;
        slow = slow.next;
        fast = fast.next.next;
    }

    prev.next = slow.next;
    this.size--;
}




// 10. Odd-Even List

oddEvenList() {
    if (!this.head) return;

    let odd = this.head;
    let even = this.head.next;
    let evenHead = even;

    while (even && even.next) {
        odd.next = even.next;
        odd = odd.next;

        even.next = odd.next;
        even = even.next;
    }

    odd.next = evenHead;
}




