// Q9. Split linked list into two halves

splitInHalf() {
    if (!this.head) return [null, null];

    let slow = this.head;
    let fast = this.head;

    while (fast.next && fast.next.next) {
        slow = slow.next;
        fast = fast.next.next;
    }

    let secondHalf = slow.next;
    slow.next = null;

    return [this.head, secondHalf];
}






// Q10. Rotate linked list by k

rotate(k) {
    if (!this.head || k === 0) return;

    let curr = this.head;
    let length = 1;

    while (curr.next) {
        curr = curr.next;
        length++;
    }

    curr.next = this.head; // make it circular

    k = k % length;
    let stepsToNewHead = length - k;

    let newTail = curr;
    let newHead = this.head;

    while (stepsToNewHead--) {
        newTail = newHead;
        newHead = newHead.next;
    }

    newTail.next = null;
    this.head = newHead;
}
